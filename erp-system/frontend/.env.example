# ── Backend API URL ────────────────────────────────────────────────
# MUST end with /api  — the axios baseURL in api.js already appends it
# if not set, it falls back to http://localhost:5000/api (dev default)
#
# Local dev:
VITE_API_URL=http://localhost:5000/api
#
# Production (via Nginx on port 80 — Nginx proxies /api/* → localhost:5000):
# VITE_API_URL=http://snugg.in/api
#
# Production (direct to Express on port 5000 — bypasses Nginx):
# VITE_API_URL=http://snugg.in:5000/api
