# ── Backend API URL ────────────────────────────────────────────────
# If not set, defaults to /api (relative — works via Nginx proxy in production)
#
# Local dev (Vite proxy OR direct to Express):
VITE_API_URL=http://localhost:5000/api
#
# Production — leave unset or use relative path (Nginx proxies /api/* → localhost:5000):
# VITE_API_URL=/api
